rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is the designated admin
    function isAdmin() {
      // Note: This requires Firebase Auth to be active
      return request.auth != null && 
             request.auth.token.email == 'maker.josesilva@educbarueri.sp.gov.br' &&
             request.auth.token.email_verified == true;
    }

    // Students collection
    match /students/{studentId} {
      allow read: if true;
      allow write: if true; // In production, restrict to isAdmin()
    }

    // Suggestions collection
    match /suggestions/{suggestionId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true; // In production, restrict to isAdmin()
    }

    // User roles
    match /users/{userId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
