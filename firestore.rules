rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to check if user is the teacher
    function isTeacher() {
      return request.auth != null && 
             request.auth.token.email == 'maker.josesilva@educbarueri.sp.gov.br' &&
             request.auth.token.email_verified == true;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) { return id is string && id.size() <= 128; }

    // Students collection
    match /students/{studentId} {
      allow read: if true;
      allow write: if isTeacher();
    }

    // Suggestions collection
    match /suggestions/{suggestionId} {
      allow read: if isTeacher() || (request.auth != null && resource.data.studentEmail == request.auth.token.email);
      allow create: if request.auth != null;
      allow update, delete: if isTeacher();
    }
  }
}
